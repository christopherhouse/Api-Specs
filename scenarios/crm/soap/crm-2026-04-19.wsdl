<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions
    name="UnifiedCrmService"
    targetNamespace="http://schemas.example.com/crm/2026/01"
    xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
    xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:tns="http://schemas.example.com/crm/2026/01">

  <!-- 
       Types
  -->
  <wsdl:types>
    <xsd:schema
        targetNamespace="http://schemas.example.com/crm/2026/01"
        elementFormDefault="qualified"
        attributeFormDefault="unqualified">

      <!-- 
           Simple types / enumerations
      -->

      <xsd:simpleType name="SourceSystem">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="salesforce"/>
          <xsd:enumeration value="dynamics"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="AccountStatus">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="active"/>
          <xsd:enumeration value="inactive"/>
          <xsd:enumeration value="prospect"/>
          <xsd:enumeration value="churned"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="LeadStatus">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="new"/>
          <xsd:enumeration value="contacted"/>
          <xsd:enumeration value="qualified"/>
          <xsd:enumeration value="disqualified"/>
          <xsd:enumeration value="converted"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="OpportunityStage">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="prospecting"/>
          <xsd:enumeration value="qualification"/>
          <xsd:enumeration value="proposal"/>
          <xsd:enumeration value="negotiation"/>
          <xsd:enumeration value="closed_won"/>
          <xsd:enumeration value="closed_lost"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="ActivityType">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="task"/>
          <xsd:enumeration value="call"/>
          <xsd:enumeration value="meeting"/>
          <xsd:enumeration value="email"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="ActivityStatus">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="planned"/>
          <xsd:enumeration value="in_progress"/>
          <xsd:enumeration value="completed"/>
          <xsd:enumeration value="cancelled"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="RelatedToType">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="account"/>
          <xsd:enumeration value="contact"/>
          <xsd:enumeration value="lead"/>
          <xsd:enumeration value="opportunity"/>
        </xsd:restriction>
      </xsd:simpleType>

      <xsd:simpleType name="LeadRating">
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="hot"/>
          <xsd:enumeration value="warm"/>
          <xsd:enumeration value="cold"/>
        </xsd:restriction>
      </xsd:simpleType>

      <!-- 
           Common complex types
      -->

      <xsd:complexType name="Address">
        <xsd:sequence>
          <xsd:element name="line1"           type="xsd:string"  minOccurs="0"/>
          <xsd:element name="line2"           type="xsd:string"  minOccurs="0"/>
          <xsd:element name="city"            type="xsd:string"  minOccurs="0"/>
          <xsd:element name="stateOrProvince" type="xsd:string"  minOccurs="0"/>
          <xsd:element name="postalCode"      type="xsd:string"  minOccurs="0"/>
          <xsd:element name="country"         type="xsd:string"  minOccurs="0"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="MonetaryAmount">
        <xsd:sequence>
          <xsd:element name="amount"   type="xsd:decimal"/>
          <xsd:element name="currency" type="xsd:string"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="SourceSystemMeta">
        <xsd:sequence>
          <xsd:element name="sourceSystem"    type="tns:SourceSystem"/>
          <xsd:element name="sourceSystemId"  type="xsd:string"/>
          <xsd:element name="sourceSystemUrl" type="xsd:anyURI"  minOccurs="0"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="PaginationMeta">
        <xsd:sequence>
          <xsd:element name="page"       type="xsd:positiveInteger"/>
          <xsd:element name="pageSize"   type="xsd:positiveInteger"/>
          <xsd:element name="totalItems" type="xsd:nonNegativeInteger"/>
          <xsd:element name="totalPages" type="xsd:nonNegativeInteger"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="ErrorDetail">
        <xsd:sequence>
          <xsd:element name="field"   type="xsd:string"/>
          <xsd:element name="message" type="xsd:string"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="ServiceFault">
        <xsd:sequence>
          <xsd:element name="code"    type="xsd:string"/>
          <xsd:element name="message" type="xsd:string"/>
          <xsd:element name="details" minOccurs="0">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="detail" type="tns:ErrorDetail" minOccurs="0" maxOccurs="unbounded"/>
              </xsd:sequence>
            </xsd:complexType>
          </xsd:element>
          <xsd:element name="traceId" type="xsd:string" minOccurs="0"/>
        </xsd:sequence>
      </xsd:complexType>

      <!-- Pagination request parameters -->
      <xsd:complexType name="PageRequest">
        <xsd:sequence>
          <xsd:element name="page"     type="xsd:positiveInteger" minOccurs="0"/>
          <xsd:element name="pageSize" type="xsd:positiveInteger" minOccurs="0"/>
        </xsd:sequence>
      </xsd:complexType>

      <!-- 
           Account types
      -->

      <xsd:complexType name="Account">
        <xsd:sequence>
          <xsd:element name="id"                  type="xsd:string"/>
          <xsd:element name="name"                type="xsd:string"/>
          <xsd:element name="status"              type="tns:AccountStatus"/>
          <xsd:element name="industry"            type="xsd:string"              minOccurs="0"/>
          <xsd:element name="website"             type="xsd:anyURI"              minOccurs="0"/>
          <xsd:element name="phone"               type="xsd:string"              minOccurs="0"/>
          <xsd:element name="billingAddress"      type="tns:Address"             minOccurs="0"/>
          <xsd:element name="annualRevenue"       type="tns:MonetaryAmount"      minOccurs="0"/>
          <xsd:element name="numberOfEmployees"   type="xsd:nonNegativeInteger"  minOccurs="0"/>
          <xsd:element name="ownerId"             type="xsd:string"              minOccurs="0"/>
          <xsd:element name="ownerName"           type="xsd:string"              minOccurs="0"/>
          <xsd:element name="description"         type="xsd:string"              minOccurs="0"/>
          <xsd:element name="sourceSystemMeta"    type="tns:SourceSystemMeta"/>
          <xsd:element name="createdAt"           type="xsd:dateTime"/>
          <xsd:element name="updatedAt"           type="xsd:dateTime"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="AccountSummary">
        <xsd:sequence>
          <xsd:element name="id"           type="xsd:string"/>
          <xsd:element name="name"         type="xsd:string"/>
          <xsd:element name="status"       type="tns:AccountStatus"/>
          <xsd:element name="industry"     type="xsd:string"          minOccurs="0"/>
          <xsd:element name="sourceSystem" type="tns:SourceSystem"/>
        </xsd:sequence>
      </xsd:complexType>

      <!-- GetAccounts -->
      <xsd:element name="GetAccountsRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="paging"       type="tns:PageRequest"      minOccurs="0"/>
            <xsd:element name="status"       type="tns:AccountStatus"    minOccurs="0"/>
            <xsd:element name="industry"     type="xsd:string"           minOccurs="0"/>
            <xsd:element name="sourceSystem" type="tns:SourceSystem"     minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetAccountsResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="account"    type="tns:AccountSummary" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element name="pagination" type="tns:PaginationMeta"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- GetAccount -->
      <xsd:element name="GetAccountRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="accountId" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetAccountResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="account" type="tns:Account"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- CreateAccount -->
      <xsd:element name="CreateAccountRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="name"                type="xsd:string"/>
            <xsd:element name="targetSourceSystem"  type="tns:SourceSystem"/>
            <xsd:element name="industry"            type="xsd:string"             minOccurs="0"/>
            <xsd:element name="website"             type="xsd:anyURI"             minOccurs="0"/>
            <xsd:element name="phone"               type="xsd:string"             minOccurs="0"/>
            <xsd:element name="billingAddress"      type="tns:Address"            minOccurs="0"/>
            <xsd:element name="annualRevenue"       type="tns:MonetaryAmount"     minOccurs="0"/>
            <xsd:element name="numberOfEmployees"   type="xsd:nonNegativeInteger" minOccurs="0"/>
            <xsd:element name="ownerId"             type="xsd:string"             minOccurs="0"/>
            <xsd:element name="description"         type="xsd:string"             minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="CreateAccountResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="account" type="tns:Account"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- UpdateAccount -->
      <xsd:element name="UpdateAccountRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="accountId"           type="xsd:string"/>
            <xsd:element name="name"                type="xsd:string"             minOccurs="0"/>
            <xsd:element name="status"              type="tns:AccountStatus"      minOccurs="0"/>
            <xsd:element name="industry"            type="xsd:string"             minOccurs="0"/>
            <xsd:element name="website"             type="xsd:anyURI"             minOccurs="0"/>
            <xsd:element name="phone"               type="xsd:string"             minOccurs="0"/>
            <xsd:element name="billingAddress"      type="tns:Address"            minOccurs="0"/>
            <xsd:element name="annualRevenue"       type="tns:MonetaryAmount"     minOccurs="0"/>
            <xsd:element name="numberOfEmployees"   type="xsd:nonNegativeInteger" minOccurs="0"/>
            <xsd:element name="ownerId"             type="xsd:string"             minOccurs="0"/>
            <xsd:element name="description"         type="xsd:string"             minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="UpdateAccountResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="account" type="tns:Account"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- DeleteAccount -->
      <xsd:element name="DeleteAccountRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="accountId" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="DeleteAccountResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="success" type="xsd:boolean"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- 
           Contact types
      -->

      <xsd:complexType name="Contact">
        <xsd:sequence>
          <xsd:element name="id"               type="xsd:string"/>
          <xsd:element name="firstName"        type="xsd:string"/>
          <xsd:element name="lastName"         type="xsd:string"/>
          <xsd:element name="email"            type="xsd:string"          minOccurs="0"/>
          <xsd:element name="phone"            type="xsd:string"          minOccurs="0"/>
          <xsd:element name="mobilePhone"      type="xsd:string"          minOccurs="0"/>
          <xsd:element name="jobTitle"         type="xsd:string"          minOccurs="0"/>
          <xsd:element name="department"       type="xsd:string"          minOccurs="0"/>
          <xsd:element name="accountId"        type="xsd:string"          minOccurs="0"/>
          <xsd:element name="accountName"      type="xsd:string"          minOccurs="0"/>
          <xsd:element name="mailingAddress"   type="tns:Address"         minOccurs="0"/>
          <xsd:element name="ownerId"          type="xsd:string"          minOccurs="0"/>
          <xsd:element name="ownerName"        type="xsd:string"          minOccurs="0"/>
          <xsd:element name="doNotContact"     type="xsd:boolean"         minOccurs="0"/>
          <xsd:element name="sourceSystemMeta" type="tns:SourceSystemMeta"/>
          <xsd:element name="createdAt"        type="xsd:dateTime"/>
          <xsd:element name="updatedAt"        type="xsd:dateTime"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="ContactSummary">
        <xsd:sequence>
          <xsd:element name="id"           type="xsd:string"/>
          <xsd:element name="firstName"    type="xsd:string"/>
          <xsd:element name="lastName"     type="xsd:string"/>
          <xsd:element name="email"        type="xsd:string"      minOccurs="0"/>
          <xsd:element name="jobTitle"     type="xsd:string"      minOccurs="0"/>
          <xsd:element name="accountName"  type="xsd:string"      minOccurs="0"/>
          <xsd:element name="sourceSystem" type="tns:SourceSystem"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:element name="GetContactsRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="paging"       type="tns:PageRequest"  minOccurs="0"/>
            <xsd:element name="accountId"    type="xsd:string"       minOccurs="0"/>
            <xsd:element name="sourceSystem" type="tns:SourceSystem" minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetContactsResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contact"    type="tns:ContactSummary" minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element name="pagination" type="tns:PaginationMeta"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="GetContactRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contactId" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetContactResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contact" type="tns:Contact"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="CreateContactRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="firstName"           type="xsd:string"/>
            <xsd:element name="lastName"            type="xsd:string"/>
            <xsd:element name="targetSourceSystem"  type="tns:SourceSystem"/>
            <xsd:element name="email"               type="xsd:string"  minOccurs="0"/>
            <xsd:element name="phone"               type="xsd:string"  minOccurs="0"/>
            <xsd:element name="mobilePhone"         type="xsd:string"  minOccurs="0"/>
            <xsd:element name="jobTitle"            type="xsd:string"  minOccurs="0"/>
            <xsd:element name="department"          type="xsd:string"  minOccurs="0"/>
            <xsd:element name="accountId"           type="xsd:string"  minOccurs="0"/>
            <xsd:element name="mailingAddress"      type="tns:Address" minOccurs="0"/>
            <xsd:element name="ownerId"             type="xsd:string"  minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="CreateContactResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contact" type="tns:Contact"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="UpdateContactRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contactId"       type="xsd:string"/>
            <xsd:element name="firstName"       type="xsd:string"  minOccurs="0"/>
            <xsd:element name="lastName"        type="xsd:string"  minOccurs="0"/>
            <xsd:element name="email"           type="xsd:string"  minOccurs="0"/>
            <xsd:element name="phone"           type="xsd:string"  minOccurs="0"/>
            <xsd:element name="mobilePhone"     type="xsd:string"  minOccurs="0"/>
            <xsd:element name="jobTitle"        type="xsd:string"  minOccurs="0"/>
            <xsd:element name="department"      type="xsd:string"  minOccurs="0"/>
            <xsd:element name="accountId"       type="xsd:string"  minOccurs="0"/>
            <xsd:element name="mailingAddress"  type="tns:Address" minOccurs="0"/>
            <xsd:element name="ownerId"         type="xsd:string"  minOccurs="0"/>
            <xsd:element name="doNotContact"    type="xsd:boolean" minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="UpdateContactResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contact" type="tns:Contact"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="DeleteContactRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="contactId" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="DeleteContactResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="success" type="xsd:boolean"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- 
           Lead types
      -->

      <xsd:complexType name="Lead">
        <xsd:sequence>
          <xsd:element name="id"               type="xsd:string"/>
          <xsd:element name="firstName"        type="xsd:string"/>
          <xsd:element name="lastName"         type="xsd:string"/>
          <xsd:element name="status"           type="tns:LeadStatus"/>
          <xsd:element name="email"            type="xsd:string"          minOccurs="0"/>
          <xsd:element name="phone"            type="xsd:string"          minOccurs="0"/>
          <xsd:element name="company"          type="xsd:string"          minOccurs="0"/>
          <xsd:element name="jobTitle"         type="xsd:string"          minOccurs="0"/>
          <xsd:element name="leadSource"       type="xsd:string"          minOccurs="0"/>
          <xsd:element name="rating"           type="tns:LeadRating"      minOccurs="0"/>
          <xsd:element name="ownerId"          type="xsd:string"          minOccurs="0"/>
          <xsd:element name="ownerName"        type="xsd:string"          minOccurs="0"/>
          <xsd:element name="description"      type="xsd:string"          minOccurs="0"/>
          <xsd:element name="sourceSystemMeta" type="tns:SourceSystemMeta"/>
          <xsd:element name="createdAt"        type="xsd:dateTime"/>
          <xsd:element name="updatedAt"        type="xsd:dateTime"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:complexType name="LeadSummary">
        <xsd:sequence>
          <xsd:element name="id"           type="xsd:string"/>
          <xsd:element name="firstName"    type="xsd:string"/>
          <xsd:element name="lastName"     type="xsd:string"/>
          <xsd:element name="status"       type="tns:LeadStatus"/>
          <xsd:element name="company"      type="xsd:string"       minOccurs="0"/>
          <xsd:element name="sourceSystem" type="tns:SourceSystem"/>
        </xsd:sequence>
      </xsd:complexType>

      <xsd:element name="GetLeadsRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="paging"       type="tns:PageRequest"  minOccurs="0"/>
            <xsd:element name="status"       type="tns:LeadStatus"   minOccurs="0"/>
            <xsd:element name="ownerId"      type="xsd:string"       minOccurs="0"/>
            <xsd:element name="sourceSystem" type="tns:SourceSystem" minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetLeadsResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="lead"       type="tns:LeadSummary"  minOccurs="0" maxOccurs="unbounded"/>
            <xsd:element name="pagination" type="tns:PaginationMeta"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="GetLeadRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="leadId" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="GetLeadResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="lead" type="tns:Lead"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="CreateLeadRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="firstName"          type="xsd:string"/>
            <xsd:element name="lastName"           type="xsd:string"/>
            <xsd:element name="targetSourceSystem" type="tns:SourceSystem"/>
            <xsd:element name="email"              type="xsd:string"      minOccurs="0"/>
            <xsd:element name="phone"              type="xsd:string"      minOccurs="0"/>
            <xsd:element name="company"            type="xsd:string"      minOccurs="0"/>
            <xsd:element name="jobTitle"           type="xsd:string"      minOccurs="0"/>
            <xsd:element name="leadSource"         type="xsd:string"      minOccurs="0"/>
            <xsd:element name="rating"             type="tns:LeadRating"  minOccurs="0"/>
            <xsd:element name="ownerId"            type="xsd:string"      minOccurs="0"/>
            <xsd:element name="description"        type="xsd:string"      minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="CreateLeadResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="lead" type="tns:Lead"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="UpdateLeadRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="leadId"       type="xsd:string"/>
            <xsd:element name="firstName"    type="xsd:string"     minOccurs="0"/>
            <xsd:element name="lastName"     type="xsd:string"     minOccurs="0"/>
            <xsd:element name="email"        type="xsd:string"     minOccurs="0"/>
            <xsd:element name="phone"        type="xsd:string"     minOccurs="0"/>
            <xsd:element name="company"      type="xsd:string"     minOccurs="0"/>
            <xsd:element name="jobTitle"     type="xsd:string"     minOccurs="0"/>
            <xsd:element name="status"       type="tns:LeadStatus" minOccurs="0"/>
            <xsd:element name="leadSource"   type="xsd:string"     minOccurs="0"/>
            <xsd:element name="rating"       type="tns:LeadRating" minOccurs="0"/>
            <xsd:element name="ownerId"      type="xsd:string"     minOccurs="0"/>
            <xsd:element name="description"  type="xsd:string"     minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="UpdateLeadResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="lead" type="tns:Lead"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="ConvertLeadRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="leadId"                 type="xsd:string"/>
            <xsd:element name="createOpportunity"      type="xsd:boolean"/>
            <xsd:element name="opportunityName"        type="xsd:string"  minOccurs="0"/>
            <xsd:element name="opportunityCloseDate"   type="xsd:date"    minOccurs="0"/>
            <xsd:element name="existingAccountId"      type="xsd:string"  minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>
      <xsd:element name="ConvertLeadResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="accountId"     type="xsd:string"/>
            <xsd:element name="contactId"     type="xsd:string"/>
            <xsd:element name="opportunityId" type="xsd:string" minOccurs="0"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <!-- 
           Opportunity types
      -->

      <xsd:complexType name="Opportunity">
        <xsd:sequence>
          <xsd:element name="id"               type="xsd:string"/>
          <xsd:element name="name"             type="xsd:string"/>
          <xsd:element name="stage"            type="tns:OpportunityStage"/>
          <xsd:element name="closeDate"        type="xsd:date"/>
          <xsd:element name="accountId"        type="xsd:string"             minOccurs="0"/>
          <xsd:element name="accountName"      type="xsd:string"             minOccurs="0"/>
          <xsd:element name="amount"           type="tns:MonetaryAmount"     minOccurs="0"/>
          <xsd:element name="probability"      type="xsd:nonNegativeInteger" minOccurs="0"/>
          <xsd:element name="ownerId"          type="xsd:string"             minOccurs="0"/>
