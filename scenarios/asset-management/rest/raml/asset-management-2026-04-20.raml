#%RAML 1.0
title: Enterprise Asset Management API
version: v1
baseUri: https://api.contoso.com/assets/v1
mediaType: application/json
description: >
  Enterprise asset management API for tracking physical assets, locations,
  categories, work orders, and audits across an organization. Supports the
  full asset lifecycle from procurement and deployment through maintenance,
  depreciation tracking, decommissioning, and disposal.

securitySchemes:
  bearerAuth:
    type: Pass Through
    describedBy:
      headers:
        Authorization:
          description: Bearer JWT token
          type: string
          pattern: "^Bearer .+"

traits:
  secured:
    headers:
      Authorization:
        description: Bearer JWT access token
        type: string
        required: true
    responses:
      401:
        description: Unauthorized
        body:
          application/json:
            type: ErrorResponse
      500:
        description: Internal server error
        body:
          application/json:
            type: ErrorResponse

  paged:
    queryParameters:
      page:
        type: integer
        minimum: 1
        default: 1
        required: false
      pageSize:
        type: integer
        minimum: 1
        maximum: 100
        default: 25
        required: false

resourceTypes:
  collection:
    get:
      is: [secured, paged]
      responses:
        200:
          description: Collection retrieved successfully
    post:
      is: [secured]
      responses:
        201:
          description: Resource created
        400:
          description: Bad request
          body:
            application/json:
              type: ErrorResponse

  item:
    get:
      is: [secured]
      responses:
        200:
          description: Resource retrieved successfully
        404:
          description: Resource not found
          body:
            application/json:
              type: ErrorResponse
    put:
      is: [secured]
      responses:
        200:
          description: Resource updated
        400:
          description: Bad request
          body:
            application/json:
              type: ErrorResponse
        404:
          description: Resource not found
          body:
            application/json:
              type: ErrorResponse
    delete:
      is: [secured]
      responses:
        204:
          description: Resource deleted
        404:
          description: Resource not found
          body:
            application/json:
              type: ErrorResponse

types:
  ErrorResponse:
    type: object
    properties:
      code:
        type: string
        required: true
      message:
        type: string
        required: true
      details:
        type: string
        required: false

  AssetStatus:
    type: string
    enum: [Active, InRepair, Reserved, Decommissioned, Disposed]

  AssetCondition:
    type: string
    enum: [New, Good, Fair, Poor, NonFunctional]

  DepreciationMethod:
    type: string
    enum: [StraightLine, DecliningBalance, SumOfYears]

  LocationType:
    type: string
    enum: [Building, Floor, Room, Warehouse, Yard, Remote]

  WorkOrderType:
    type: string
    enum: [Preventive, Corrective, Emergency, Inspection]

  WorkOrderPriority:
    type: string
    enum: [Critical, High, Medium, Low]

  WorkOrderStatus:
    type: string
    enum: [Open, Assigned, InProgress, OnHold, Completed, Cancelled]

  Address:
    type: object
    properties:
      street:
        type: string
        required: true
      city:
        type: string
        required: true
      state:
        type: string
        required: true
      zipCode:
        type: string
        required: true
      country:
        type: string
        required: true

  Category:
    type: object
    properties:
      categoryId:
        type: string
        required: true
      name:
        type: string
        required: true
      description:
        type: string
        required: false
      parentCategoryId:
        type: string
        required: false
      depreciationMethod:
        type: DepreciationMethod
        required: false
      usefulLifeYears:
        type: integer
        required: false
      createdAt:
        type: datetime
        required: true
      updatedAt:
        type: datetime
        required: true

  Location:
    type: object
    properties:
      locationId:
        type: string
        required: true
      name:
        type: string
        required: true
      locationType:
        type: LocationType
        required: true
      description:
        type: string
        required: false
      address:
        type: Address
        required: false
      parentLocationId:
        type: string
        required: false
      managerName:
        type: string
        required: false
      managerEmail:
        type: string
        required: false
      capacity:
        type: integer
        required: false
      isActive:
        type: boolean
        required: true
      createdAt:
        type: datetime
        required: true
      updatedAt:
        type: datetime
        required: true

  Asset:
    type: object
    properties:
      assetId:
        type: string
        required: true
      assetTag:
        type: string
        required: true
      name:
        type: string
        required: true
      description:
        type: string
        required: false
      categoryId:
        type: string
        required: true
      locationId:
        type: string
        required: true
      status:
        type: AssetStatus
        required: true
      condition:
        type: AssetCondition
        required: true
      serialNumber:
        type: string
        required: false
      manufacturer:
        type: string
        required: false
      model:
        type: string
        required: false
      purchaseDate:
        type: date-only
        required: false
      purchasePrice:
        type: number
        required: false
      warrantyExpiration:
        type: date-only
        required: false
      depreciationMethod:
        type: DepreciationMethod
        required: false
      usefulLifeYears:
        type: integer
        required: false
      salvageValue:
        type: number
        required: false
      currentValue:
        type: number
        required: false
      assignedTo:
        type: string
        required: false
      notes:
        type: string
        required: false
      createdAt:
        type: datetime
        required: true
      updatedAt:
        type: datetime
        required: true

  WorkOrder:
    type: object
    properties:
      workOrderId:
        type: string
        required: true
      assetId:
        type: string
        required: true
      title:
        type: string
        required: true
      description:
        type: string
        required: false
      workOrderType:
        type: WorkOrderType
        required: true
      priority:
        type: WorkOrderPriority
        required: true
      status:
        type: WorkOrderStatus
        required: true
      assignedTo:
        type: string
        required: false
      reportedBy:
        type: string
        required: true
      scheduledDate:
        type: date-only
        required: false
      completedDate:
        type: date-only
        required: false
      estimatedCost:
        type: number
        required: false
      actualCost:
        type: number
        required: false
      laborHours:
        type: number
        required: false
      resolutionNotes:
        type: string
        required: false
      createdAt:
        type: datetime
        required: true
      updatedAt:
        type: datetime
        required: true

  Audit:
    type: object
    properties:
      auditId:
        type: string
        required: true
      assetId:
        type: string
        required: true
      auditorName:
        type: string
        required: true
      auditDate:
        type: date-only
        required: true
      locationId:
        type: string
        required: false
      conditionAssessed:
        type: AssetCondition
        required: true
      currentValue:
        type: number
        required: false
      notes:
        type: string
        required: false
      discrepancies:
        type: string
        required: false
      verified:
        type: boolean
        required: true
      createdAt:
        type: datetime
        required: true

  CreateAsset:
    type: object
    properties:
      assetTag:
        type: string
        required: true
      name:
        type: string
        required: true
      description:
        type: string
        required: false
      categoryId:
        type: string
        required: true
      locationId:
        type: string
        required: true
      condition:
        type: AssetCondition
        required: true
      serialNumber:
        type: string
        required: false
      manufacturer:
        type: string
        required: false
      model:
        type: string
        required: false
      purchaseDate:
        type: date-only
        required: false
      purchasePrice:
        type: number
        required: false
      warrantyExpiration:
        type: date-only
        required: false
      depreciationMethod:
        type: DepreciationMethod
        required: false
      usefulLifeYears:
        type: integer
        required: false
      salvageValue:
        type: number
        required: false
      assignedTo:
        type: string
        required: false
      notes:
        type: string
        required: false

  UpdateAsset:
    type: object
    properties:
      name:
        type: string
        required: false
      description:
        type: string
        required: false
      categoryId:
        type: string
        required: false
      locationId:
        type: string
        required: false
      condition:
        type: AssetCondition
        required: false
      serialNumber:
        type: string
        required: false
      manufacturer:
        type: string
        required: false
      model:
        type: string
        required: false
      warrantyExpiration:
        type: date-only
        required: false
      depreciationMethod:
        type: DepreciationMethod
        required: false
      usefulLifeYears:
        type: integer
        required: false
      salvageValue:
        type: number
        required: false
      assignedTo:
        type: string
        required: false
      notes:
        type: string
        required: false

  CreateCategory:
    type: object
    properties:
      name:
        type: string
        required: true
      description:
        type: string
        required: false
      parentCategoryId:
        type: string
        required: false
      depreciationMethod:
        type: DepreciationMethod
        required: false
      usefulLifeYears:
        type: integer
        required: false

  UpdateCategory:
    type: object
    properties:
      name:
        type: string
        required: false
      description:
        type: string
        required: false
      parentCategoryId:
        type: string
        required: false
      depreciationMethod:
        type: DepreciationMethod
        required: false
      usefulLifeYears:
        type: integer
        required: false

  CreateLocation:
    type: object
    properties:
      name:
        type: string
        required: true
      locationType:
        type: LocationType
        required: true
      description:
        type: string
        required: false
      address:
        type: Address
        required: false
      parentLocationId:
        type: string
        required: false
      managerName:
        type: string
        required: false
      managerEmail:
        type: string
        required: false
      capacity:
        type: integer
        required: false

  UpdateLocation:
    type: object
    properties:
      name:
        type: string
        required: false
      locationType:
        type: LocationType
        required: false
      description:
        type: string
        required: false
      address:
        type: Address
        required: false
      parentLocationId:
        type: string
        required: false
      managerName:
        type: string
        required: false
      managerEmail:
        type: string
        required: false
      capacity:
        type: integer
        required: false
      isActive:
        type: boolean
        required: false

  CreateWorkOrder:
    type: object
    properties:
      assetId:
        type: string
        required: true
      title:
        type: string
        required: true
      description:
        type: string
        required: false
      workOrderType:
        type: WorkOrderType
        required: true
      priority:
        type: WorkOrderPriority
        required: true
      assignedTo:
        type: string
        required: false
      reportedBy:
        type: string
        required: true
      scheduledDate:
        type: date-only
        required: false
      estimatedCost:
        type: number
        required: false

  UpdateWorkOrder:
    type: object
    properties:
      title:
        type: string
        required: false
      description:
        type: string
        required: false
      priority:
        type: WorkOrderPriority
        required: false
      status:
        type: WorkOrderStatus
        required: false
      assignedTo:
        type: string
        required: false
      scheduledDate:
        type: date-only
        required: false
      estimatedCost:
        type: number
        required: false
      actualCost:
        type: number
        required: false
      laborHours:
        type: number
        required: false
      resolutionNotes:
        type: string
        required: false

  CreateAudit:
    type: object
    properties:
      assetId:
        type: string
        required: true
      auditorName:
        type: string
        required: true
      auditDate:
        type: date-only
        required: true
      locationId:
        type: string
        required: false
      conditionAssessed:
        type: AssetCondition
        required: true
      currentValue:
        type: number
        required: false
      notes:
        type: string
        required: false
      discrepancies:
        type: string
        required: false
      verified:
        type: boolean
        required: true

  DecommissionRequest:
    type: object
    properties:
      reason:
        type: string
        required: true
      disposalMethod:
        type: string
        required: false
      approvedBy:
        type: string
        required: true
      effectiveDate:
        type: date-only
        required: true

  CompleteWorkOrderRequest:
    type: object
    properties:
      resolutionNotes:
        type: string
        required: true
      actualCost:
        type: number
        required: false
      laborHours:
        type: number
        required: false
      completedDate:
        type: date-only
        required: true

  AssetList:
    type: object
    properties:
      items:
        type: Asset[]
        required: true
      totalCount:
        type: integer
        required: true

  CategoryList:
    type: object
    properties:
      items:
        type: Category[]
        required: true
      totalCount:
        type: integer
        required: true

  LocationList:
    type: object
    properties:
      items:
        type: Location[]
        required: true
      totalCount:
        type: integer
        required: true

  WorkOrderList:
    type: object
    properties:
      items:
        type: WorkOrder[]
        required: true
      totalCount:
        type: integer
        required: true

  AuditList:
    type: object
    properties:
      items:
        type: Audit[]
        required: true
      totalCount:
        type: integer
        required: true

/assets:
  type: collection
  description: Manage physical assets tracked by the organization.
  get:
    description: Retrieve a paginated list of assets with optional filters.
    queryParameters:
      status:
        type: AssetStatus
        required: false
        description: Filter assets by status.
      categoryId:
        type: string
        required: false
        description: Filter assets by category identifier.
      locationId:
        type: string
        required: false
        description: Filter assets by location identifier.
    responses:
      200:
        body:
          application/json:
            type: AssetList
  post:
    description: Register a new asset in the system.
    body:
      application/json:
        type: CreateAsset
    responses:
      201:
        body:
          application/json:
            type: Asset

  /{assetId}:
    type: item
    description: Operations on a single asset identified by its unique ID.
    uriParameters:
      assetId:
        type: string
        description: Unique identifier of the asset.
    get:
      description: Retrieve full details of a specific asset.
      responses:
        200:
          body:
            application/json:
              type: Asset
    put:
      description: Update an existing asset's information.
      body:
        application/json:
          type: UpdateAsset
      responses:
        200:
          body:
            application/json:
              type: Asset
    delete:
      description: Remove an asset record from the system.

    /decommission:
      description: Decommission an asset, removing it from active service.
      post:
        is: [secured]
        description: Decommission the specified asset with a reason and approval.
        body:
          application/json:
            type: DecommissionRequest
        responses:
          200:
            description: Asset decommissioned successfully
            body:
              application/json:
                type: Asset
          400:
            description: Bad request
            body:
              application/json:
                type: ErrorResponse
          404:
            description: Asset not found
            body:
              application/json:
                type: ErrorResponse

/categories:
  type: collection
  description: Manage asset categories used to classify and group assets.
  get:
    description: Retrieve a paginated list of asset categories.
    responses:
      200:
        body:
          application/json:
            type: CategoryList
  post:
    description: Create a new asset category.
    body:
      application/json:
        type: CreateCategory
    responses:
      201:
        body:
          application/json:
            type: Category

  /{categoryId}:
    type: item
    description: Operations on a single asset category.
    uriParameters:
      categoryId:
        type: string
        description: Unique identifier of the category.
    get:
      description: Retrieve details of a specific category.
      responses:
        200:
          body:
            application/json:
              type: Category
    put:
      description: Update an existing category.
      body:
        application/json:
          type: UpdateCategory
      responses:
        200:
          body:
            application/json:
              type: Category
    delete:
      description: Delete a category if it has no associated assets.

/locations:
  type: collection
  description: Manage physical locations where assets are deployed or stored.
  get:
    description: Retrieve a paginated list of locations with optional filters.
    queryParameters:
      locationType:
        type: LocationType
        required: false
        description: Filter locations by type.
    responses:
      200:
        body:
          application/json:
            type: LocationList
  post:
    description: Create a new location record.
    body:
      application/json:
        type: CreateLocation
    responses:
      201:
        body:
          application/json:
            type: Location

  /{locationId}:
    description: Operations on a single location.
    uriParameters:
      locationId:
        type: string
        description: Unique identifier of the location.
    get:
      is: [secured]
      description: Retrieve details of a specific location.
      responses:
        200:
          description: Location retrieved successfully
          body:
            application/json:
              type: Location
        404:
          description: Location not found
          body:
            application/json:
              type: ErrorResponse
    put:
      is: [secured]
      description: Update an existing location.
      body:
        application/json:
          type: UpdateLocation
      responses:
        200:
          description: Location updated
          body:
            application/json:
              type: Location
        400:
          description: Bad request
          body:
            application/json:
              type: ErrorResponse
        404:
          description: Location not found
          body:
            application/json:
              type: ErrorResponse

/work-orders:
  type: collection
  description: Manage work orders for asset maintenance and repair.
  get:
    description: Retrieve a paginated list of work orders with optional filters.
    queryParameters:
      assetId:
        type: string
        required: false
        description: Filter work orders by asset identifier.
      status:
        type: WorkOrderStatus
        required: false
        description: Filter work orders by status.
      priority:
        type: WorkOrderPriority
        required: false
        description: Filter work orders by priority level.
    responses:
      200:
        body:
          application/json:
            type: WorkOrderList
  post:
    description: Create a new work order for an asset.
    body:
      application/json:
        type: CreateWorkOrder
    responses:
      201:
        body:
          application/json:
            type: WorkOrder

  /{workOrderId}:
    description: Operations on a single work order.
    uriParameters:
      workOrderId:
        type: string
        description: Unique identifier of the work order.
    get:
      is: [secured]
      description: Retrieve details of a specific work order.
      responses:
        200:
          description: Work order retrieved successfully
          body:
            application/json:
              type: WorkOrder
        404:
          description: Work order not found
          body:
            application/json:
              type: ErrorResponse
    put:
      is: [secured]
      description: Update an existing work order.
      body:
        application/json:
          type: UpdateWorkOrder
      responses:
        200:
          description: Work order updated
          body:
            application/json:
              type: WorkOrder
        400:
          description: Bad request
          body:
            application/json:
              type: ErrorResponse
        404:
          description: Work order not found
          body:
            application/json:
              type: ErrorResponse

    /complete:
      description: Mark a work order as completed with resolution details.
      post:
        is: [secured]
        description: Complete the specified work order with resolution information.
        body:
          application/json:
            type: CompleteWorkOrderRequest
        responses:
          200:
            description: Work order completed successfully
            body:
              application/json:
                type: WorkOrder
          400:
            description: Bad request
            body:
              application/json:
                type: ErrorResponse
          404:
            description: Work order not found
            body:
              application/json:
                type: ErrorResponse

/audits:
  type: collection
  description: Manage asset audit records for compliance and verification.
  get:
    description: Retrieve a paginated list of audits with optional filters.
    queryParameters:
      assetId:
        type: string
        required: false
        description: Filter audits by asset identifier.
    responses:
      200:
        body:
          application/json:
            type: AuditList
  post:
    description: Record a new asset audit.
    body:
      application/json:
        type: CreateAudit
    responses:
      201:
        body:
          application/json:
            type: Audit

  /{auditId}:
    description: Retrieve a single audit record.
    uriParameters:
      auditId:
        type: string
        description: Unique identifier of the audit.
    get:
      is: [secured]
      description: Retrieve details of a specific audit record.
      responses:
        200:
          description: Audit retrieved successfully
          body:
            application/json:
              type: Audit
        404:
          description: Audit not found
          body:
            application/json:
              type: ErrorResponse
