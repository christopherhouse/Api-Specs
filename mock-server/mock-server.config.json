{
  "port": 3000,
  "host": "0.0.0.0",
  "cors": {
    "origin": "*",
    "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "allowedHeaders": ["Content-Type", "Authorization"],
    "credentials": false,
    "maxAge": 86400
  },
  "tls": {
    "enabled": false,
    "keyFile": "./certs/server.key",
    "certFile": "./certs/server.crt"
  },
  "responseDelay": {
    "enabled": false,
    "minMs": 0,
    "maxMs": 1000
  },
  "bodyLimit": "1mb"
}
